# Conduit Configuration
# Copy this to .env and fill in your values

# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# ─── PostgreSQL (pgvector) ───────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=conduit
POSTGRES_PASSWORD=your-password-here
POSTGRES_DB=conduit
POSTGRES_SSL=disable

# ─── ArangoDB (graph store) ──────────────────────────────
ARANGO_URL=http://localhost:8529
ARANGO_USERNAME=root
ARANGO_PASSWORD=your-password-here
ARANGO_DATABASE=conduit

# ─── OpenAI (embeddings + synthesis) ─────────────────────
OPENAI_API_KEY=sk-your-key-here
EMBEDDINGS_PROVIDER=openai
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_EMBED_DIMENSIONS=1536

# ─── Conduit API Keys ───────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONDUIT_API_KEY=generate-a-random-key
CONDUIT_ADMIN_KEY=generate-a-random-admin-key

# ─── Optional: Ollama (local LLM alternative) ───────────
# OLLAMA_URL=http://localhost:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_EMBED_DIMENSIONS=768

# ─── Optional: AWS Cognito (console SSO) ────────────────
# COGNITO_USER_POOL_ID=
# COGNITO_CLIENT_ID=
# COGNITO_DOMAIN=
